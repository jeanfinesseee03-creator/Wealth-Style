* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #050816;
  color: white;
  font-family: Arial, sans-serif;
}

header {
  display: flex;
  justify-content: space-between;
  padding: 20px 50px;
  background: rgba(0,0,0,.6);
  position: sticky;
  top: 0;
}

nav a {
  color: white;
  text-decoration: none;        
  margin-left: 20px;
}

.hero {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.stars {
  position: absolute;
  inset: 0;
  background-image:
  radial-gradient(white 1px, transparent 1px);
  background-size: 50px 50px;
  animation: sparkle 8s linear infinite;
  opacity: .7;
}

@keyframes sparkle {
  from {transform: translateY(0);}
  to {transform: translateY(-100px);}
}

.products {
  display: flex;
  gap: 30px;
  padding: 40px;
  flex-wrap: wrap;
}

.product {
  width: 300px;
  background: rgba(255,255,255,.05);
  padding: 20px;
  border-radius: 15px;
}

.product img {
  width: 100%;
  border-radius: 10px;
}

